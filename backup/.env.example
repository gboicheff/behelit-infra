# Lives at /etc/backups/.env on the VPS. chmod 600, owned by root.
# DO NOT commit a real version of this file.

# Name of the B2 bucket created in the Backblaze UI.
B2_BUCKET=behelit-backups

# rclone remote name (matches the [...] section in /root/.config/rclone/rclone.conf).
RCLONE_REMOTE=b2-backups

# Optional: how many days of backups to keep. Default 30.
# RETENTION_DAYS=30
